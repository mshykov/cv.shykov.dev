# Cloudflare Pages headers. Applied to every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' data: blob:; base-uri 'none'; form-action 'none'; frame-ancestors 'none'

# Content-hashed assets never change — cache them hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML must always revalidate, or the browser serves a stale index that points
# at old (possibly broken) chunk hashes. This is what pinned iOS Safari to an
# old build even after fixes deployed.
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
# Keep the self-destruct service worker uncached so clients pick up its removal.
/sw.js
  Cache-Control: no-cache
